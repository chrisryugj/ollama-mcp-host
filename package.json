{
  "name": "ollama-mcp-host",
  "version": "0.1.1",
  "description": "Run multiple MCP servers with a local Ollama model (gemma & other tool-capable models). One model auto-selects and calls tools across stdio MCP servers — e.g. korean-law-mcp + kordoc. Cloud-free, air-gapped friendly, single runtime dependency. CLI + library.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ollama-mcp-host": "dist/cli.js"
  },
  "files": [
    "dist",
    "mcp.config.example.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "ollama",
    "gemma",
    "model-context-protocol",
    "korean-law-mcp",
    "kordoc",
    "llm",
    "offline",
    "on-premise"
  ],
  "author": "chrisryugj <ryuseungin@naver.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisryugj/ollama-mcp-host.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
